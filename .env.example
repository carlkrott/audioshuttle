# AudioShuttle Configuration
# Copy this file to .env and adjust values

# Model paths (host paths mounted into e4b container)
# Download model files from HuggingFace:
#   - https://huggingface.co/<user>/gemma-4-E4B-it-UD-Q4_K_XL.gguf
#   - https://huggingface.co/<user>/gemma-4-e4b-mmproj-BF16.gguf
# Place them in ./models/ directory

# Model API URL (default: http://e4b:8102/v1/chat/completions)
# AUDIOSHUTTLE_MODEL_API_URL=http://e4b:8102/v1/chat/completions

# Reaper DAW connection (host must have Reaper running with OSC enabled)
# AUDIOSHUTTLE_REAPER_HOST=host.docker.internal
# AUDIOSHUTTLE_REAPER_SEND_PORT=8000
# AUDIOSHUTTLE_REAPER_FEEDBACK_PORT=9000

# Web UI
# AUDIOSHUTTLE_HOST=0.0.0.0
# AUDIOSHUTTLE_PORT=8765

# Logging
# AUDIOSHUTTLE_LOG_LEVEL=INFO

# E4B model context size
# E4B_CONTEXT_SIZE=81920

# GPU acceleration (set >0 if GPU passthrough available)
# E4B_N_GPU_LAYERS=0